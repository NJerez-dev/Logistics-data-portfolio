      "source": [
        "import pandas as pd\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "\n",
        "sns.set_style(\"whitegrid\")\n",
        "\n",
        "# Ensure df is loaded if not already in session\n",
        "# This line is added to handle potential kernel restarts or out-of-order execution\n",
        "df = pd.read_csv(\"inventory_transactions.csv\")\n",
        "\n",
        "# --- Re-calculate product_kpis to ensure it's defined ---\n",
        "daily_demand = df.groupby(['product_id', 'date'])['units_sold'].sum().reset_index()\n",
        "\n",
        "product_demand_stats = daily_demand.groupby('product_id')['units_sold'].agg([\n",
        "    'mean',\n",
        "    'std'\n",
        "]).reset_index()\n",
        "\n",
        "product_demand_stats.rename(columns={\n",
        "    'mean': 'avg_daily_demand',\n",
        "    'std': 'std_dev_daily_demand'\n",
        "}, inplace=True)\n",
        "\n",
        "# Merge with product details to get supplier_lead_time\n",
        "product_kpis = pd.merge(product_demand_stats, df[['product_id', 'supplier_lead_time']].drop_duplicates(), on='product_id')\n",
        "\n",
        "# Define Z-score for a desired service level (e.g., 95% service level = Z-score of 1.645)\n",
        "Z = 1.645 # Ensure Z is defined\n",
        "\n",
        "# Calculate Safety Stock (Stock de Emergencia)\n",
        "# SS = Z * std_dev_demand * sqrt(lead_time)\n",
        "product_kpis['safety_stock'] = (Z * product_kpis['std_dev_daily_demand'] * np.sqrt(product_kpis['supplier_lead_time'])).fillna(0).astype(int)\n",
        "\n",
        "# Calculate Reorder Point (Stock de Reposición)\n",
        "# ROP = (avg_daily_demand * lead_time) + Safety Stock\n",
        "product_kpis['reorder_point_calculated'] = (product_kpis['avg_daily_demand'] * product_kpis['supplier_lead_time'] + product_kpis['safety_stock']).astype(int)\n",
        "# --- End re-calculation of product_kpis ---\n",
        "\n",
        "# Calcular el ingreso total por producto\n",
        "total_revenue_per_product = df.groupby('product_id')['revenue'].sum().reset_index()\n",
        "total_revenue_per_product.rename(columns={'revenue': 'total_revenue'}, inplace=True)\n",
        "\n",
        "# Unir el ingreso total con los KPIs de producto\n",
        "product_kpis_ranked = pd.merge(product_kpis, total_revenue_per_product, on='product_id')\n",
        "\n",
        "# Ordenar productos por ingreso total\n",
        "product_kpis_ranked = product_kpis_ranked.sort_values(by='total_revenue', ascending=False).reset_index(drop=True)\n",
        "\n",
        "# Seleccionar Top 5, Middle 5 y Bottom 5 productos\n",
        "n_products_total = len(product_kpis_ranked)\n",
        "top_5_products = product_kpis_ranked.head(5)\n",
        "middle_start_index = max(5, (n_products_total // 2) - 2) # Asegurarse de no empezar antes del 5to producto\n",
        "middle_end_index = min(n_products_total - 5, (n_products_total // 2) + 2) # Asegurarse de no terminar en los últimos 5\n",
        "middle_5_products = product_kpis_ranked.iloc[middle_start_index:middle_end_index + 1]\n",
        "bottom_5_products = product_kpis_ranked.tail(5)\n",
        "\n",
        "# Combinar los DataFrames seleccionados\n",
        "selected_products_kpis = pd.concat([top_5_products, middle_5_products, bottom_5_products])\n",
        "\n",
        "# Agregar una columna para identificar el grupo (Top, Middle, Bottom)\n",
        "selected_products_kpis.loc[top_5_products.index, 'Group'] = 'Top Revenue'\n",
        "selected_products_kpis.loc[middle_5_products.index, 'Group'] = 'Middle Revenue'\n",
        "selected_products_kpis.loc[bottom_5_products.index, 'Group'] = 'Bottom Revenue'\n",
        "\n",
        "# Unir con nombres de producto para la visualización\n",
        "product_names = df[['product_id', 'product_name']].drop_duplicates()\n",
        "selected_products_kpis = pd.merge(selected_products_kpis, product_names, on='product_id')\n",
        "\n",
        "# Ordenar para la visualización\n",
        "selected_products_kpis['sort_order'] = selected_products_kpis['Group'].map({'Top Revenue': 1, 'Middle Revenue': 2, 'Bottom Revenue': 3})\n",
        "selected_products_kpis = selected_products_kpis.sort_values(by=['sort_order', 'total_revenue'], ascending=[True, False])\n",
        "\n",
        "# Crear el gráfico de barras apiladas\n",
        "fig, ax = plt.subplots(figsize=(15, 8))\n",
        "\n",
        "bottom_values = np.zeros(len(selected_products_kpis))\n",
        "\n",
        "# Plot Reorder Point\n",
        "p1 = ax.bar(\n",
        "    selected_products_kpis['product_name'] + ' (' + selected_products_kpis['Group'] + ')',\n",
        "    selected_products_kpis['reorder_point_calculated'],\n",
        "    label='Punto de Reorden',\n",
        "    color='skyblue'\n",
        ")\n",
        "\n",
        "# Plot Safety Stock on top of Reorder Point (for total optimal stock visual)\n",
        "p2 = ax.bar(\n",
        "    selected_products_kpis['product_name'] + ' (' + selected_products_kpis['Group'] + ')',\n",
        "    selected_products_kpis['safety_stock'],\n",
        "    bottom=selected_products_kpis['reorder_point_calculated'] - selected_products_kpis['safety_stock'], # Adjusted to show SS as distinct from Demand During Lead Time within ROP\n",
        "    label='Stock de Seguridad',\n",
        "    color='salmon'\n",
        ")\n",
        "\n",
        "ax.set_title('Cantidad Óptima (Punto de Reorden y Stock de Seguridad) por Producto', fontsize=16)\n",
        "ax.set_xlabel('Producto (Grupo de Ventas)', fontsize=12)\n",
        "ax.set_ylabel('Cantidad de Unidades', fontsize=12)\n",
        "plt.xticks(rotation=60, ha='right', fontsize=10)\n",
        "ax.ticklabel_format(style='plain', axis='y')\n",
        "ax.legend()\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ],
